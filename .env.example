VITE_SITE_URL=https://macadent.com.my

# CMS adapter mode:
# - auto: try platform endpoint, fall back to local content
# - platform: require platform endpoint
# - local: always use local fallback content
VITE_CMS_MODE=auto

# Optional diagnostics visibility on public pages (source badges + slot-key hints)
# Set true only for internal QA environments.
VITE_SHOW_CMS_DIAGNOSTICS=false

# Kardal CMS platform base URL (example: http://localhost:4100 or your deployed CMS host)
VITE_CMS_PLATFORM_BASE_URL=http://localhost:4100

# Tenant routing (set one)
VITE_CMS_TENANT_SLUG=macadent
# VITE_CMS_TENANT_ID=

# Optional if your platform public endpoint later requires auth
# VITE_CMS_API_TOKEN=
